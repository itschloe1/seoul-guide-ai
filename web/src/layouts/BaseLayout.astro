---
import Logo from '../components/Logo.astro';

interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
}

const { title, description, ogTitle, ogDescription, ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage || '/og/default.png', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="VEOLPb-K3xZz36652lAuuZuj2-7S9okyl-D5PCY2cmU" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={ogDescription || description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Living in Korea" />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle || title} />
    <meta name="twitter:description" content={ogDescription || description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <slot name="head" />
    <!-- Vercel Analytics -->
    <script is:inline defer src="/_vercel/insights/script.js"></script>
  </head>
  <body>
    <header>
      <nav>
        <div class="nav-inner">
          <Logo />
          <ul class="nav-links">
            <li><a href="/guides/">Guides</a></li>
            <li><a href="/about/">About</a></li>
            <li><a href="https://t.me/livinginkorea_bot" target="_blank" rel="noopener" class="cta-link">Try the Bot</a></li>
          </ul>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <p>&copy; {new Date().getFullYear()} Living in Korea. <a href="/guides/">Guides</a> &middot; <a href="/about/">About</a> &middot; <a href="https://t.me/livinginkorea_bot" target="_blank" rel="noopener">Telegram Bot</a></p>
      </div>
    </footer>

    <style is:global>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --cream: #FFF8F0;
        --cream-dark: #FFF1E0;
        --coral: #E8725C;
        --coral-light: #FDECE8;
        --sage: #7BA085;
        --sage-light: #EDF5EF;
        --navy: #003478;
        --navy-dark: #0A0E2A;
        --blue: #1A56DB;
        --text: #1A1A2E;
        --text-light: #5A5A7A;
        --white: #FFFFFF;
        --gradient-kculture: linear-gradient(135deg, #E8725C 0%, #C060A1 50%, #6C5CE7 100%);
        --max-width: 780px;
        --max-width-wide: 1100px;
        /* Legacy aliases for components that still reference old variable names */
        --color-primary: #E8725C;
        --color-primary-dark: #d45a44;
        --color-primary-light: #FDECE8;
        --color-text: #1A1A2E;
        --color-text-light: #5A5A7A;
        --color-bg: #FFF8F0;
        --color-bg-alt: #FFF1E0;
        --color-border: rgba(0, 0, 0, 0.08);
        --color-accent: #7BA085;
      }

      html {
        font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        font-size: 17px;
        line-height: 1.7;
        color: var(--text);
        background: var(--cream);
        -webkit-font-smoothing: antialiased;
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Outfit', -apple-system, sans-serif;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: var(--cream);
      }

      main {
        flex: 1;
      }

      a {
        color: var(--coral);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      img {
        max-width: 100%;
        height: auto;
      }

      /* Header */
      header {
        position: sticky;
        top: 0;
        z-index: 100;
        background: rgba(255, 248, 240, 0.9);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(0, 52, 120, 0.08);
      }
      nav {
        max-width: var(--max-width-wide);
        margin: 0 auto;
        padding: 0 2rem;
      }
      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }
      .logo {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-weight: 700;
        font-size: 1.15rem;
        color: var(--navy);
        text-decoration: none;
      }
      .nav-links {
        list-style: none;
        display: flex;
        gap: 2rem;
        align-items: center;
      }
      .nav-links a {
        color: var(--text-light);
        font-size: 0.92rem;
        font-weight: 500;
        transition: color 0.2s;
      }
      .nav-links a:hover {
        color: var(--coral);
        text-decoration: none;
      }
      .cta-link {
        background: var(--coral) !important;
        color: #fff !important;
        padding: 0.5rem 1.2rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.88rem !important;
        transition: transform 0.2s, box-shadow 0.2s;
      }
      .cta-link:hover {
        transform: translateY(-1px);
        box-shadow: 0 4px 15px rgba(232, 114, 92, 0.35);
        background: var(--coral) !important;
      }

      /* Footer */
      footer {
        padding: 2.5rem 2rem;
        background: var(--cream);
        border-top: 1px solid rgba(0, 0, 0, 0.06);
        text-align: center;
        margin-top: 0;
      }
      .footer-inner {
        max-width: var(--max-width-wide);
        margin: 0 auto;
      }
      footer p {
        color: var(--text-light);
        font-size: 0.85rem;
      }
      footer a {
        color: var(--coral);
        text-decoration: none;
      }
      footer a:hover {
        text-decoration: underline;
      }

      /* Buttons */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 0.8rem 1.8rem;
        border-radius: 50px;
        font-weight: 600;
        font-size: 1rem;
        text-decoration: none;
        transition: all 0.2s;
        font-family: inherit;
        border: none;
        cursor: pointer;
      }
      .btn-primary {
        background: var(--coral);
        color: #fff;
        box-shadow: 0 4px 15px rgba(232, 114, 92, 0.3);
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 25px rgba(232, 114, 92, 0.4);
        text-decoration: none;
      }
      .btn-outline {
        background: white;
        color: var(--text);
        border: 1.5px solid rgba(26, 26, 46, 0.15);
      }
      .btn-outline:hover {
        border-color: var(--coral);
        color: var(--coral);
        text-decoration: none;
      }

      /* Article content typography */
      .article-content {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
      }
      .article-content h1 {
        font-size: 2rem;
        line-height: 1.25;
        margin-bottom: 0.5rem;
        color: var(--navy-dark);
      }
      .article-content h2 {
        font-size: 1.5rem;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.08);
        color: var(--navy-dark);
      }
      .article-content h3 {
        font-size: 1.2rem;
        margin-top: 2rem;
        margin-bottom: 0.5rem;
        color: var(--navy-dark);
      }
      .article-content h4 {
        font-size: 1.05rem;
        margin-top: 1.5rem;
        margin-bottom: 0.4rem;
      }
      .article-content p {
        margin-bottom: 1rem;
      }
      .article-content ul,
      .article-content ol {
        margin-bottom: 1rem;
        padding-left: 1.5rem;
      }
      .article-content li {
        margin-bottom: 0.35rem;
      }
      .article-content blockquote {
        border-left: 4px solid var(--coral);
        padding: 0.75rem 1rem;
        margin: 1.5rem 0;
        background: var(--coral-light);
        border-radius: 0 6px 6px 0;
        font-style: italic;
      }
      .article-content table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.92rem;
        overflow-x: auto;
        display: block;
      }
      .article-content th,
      .article-content td {
        border: 1px solid rgba(0, 0, 0, 0.08);
        padding: 0.5rem 0.75rem;
        text-align: left;
      }
      .article-content th {
        background: var(--cream-dark);
        font-weight: 600;
      }
      .article-content code {
        background: var(--cream-dark);
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9em;
      }
      .article-content pre {
        background: #1e293b;
        color: #e2e8f0;
        padding: 1rem;
        border-radius: 8px;
        overflow-x: auto;
        margin: 1.5rem 0;
      }
      .article-content pre code {
        background: none;
        padding: 0;
        color: inherit;
      }
      .article-content hr {
        border: none;
        border-top: 1px solid rgba(0, 0, 0, 0.08);
        margin: 2rem 0;
      }
      .article-content strong {
        font-weight: 600;
      }

      /* Guide meta */
      .guide-meta {
        color: var(--text-light);
        font-size: 0.88rem;
        margin-bottom: 1.5rem;
      }

      /* Guide CTA */
      .guide-cta {
        background: var(--coral-light);
        border: 1px solid rgba(232, 114, 92, 0.2);
        border-radius: 14px;
        padding: 1.5rem;
        margin-top: 3rem;
        text-align: center;
      }
      .guide-cta p {
        margin-bottom: 0.75rem;
        color: var(--text);
      }

      @media (max-width: 640px) {
        html {
          font-size: 16px;
        }
        nav {
          padding: 0 1rem;
        }
        .nav-inner {
          height: 56px;
        }
        .logo {
          font-size: 0.95rem;
          white-space: nowrap;
        }
        .nav-links {
          gap: 1rem;
        }
        .nav-links a {
          font-size: 0.82rem;
        }
        .cta-link {
          padding: 0.3rem 0.6rem;
          font-size: 0.78rem !important;
        }
        .article-content h1 {
          font-size: 1.6rem;
        }
        .article-content h2 {
          font-size: 1.3rem;
        }
      }
    </style>
  </body>
</html>
