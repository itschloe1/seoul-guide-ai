---
interface Props {
  size?: number;
}

const { size = 28 } = Astro.props;
---

<a href="/" class="logo">
  <svg
    width={size}
    height={size}
    viewBox="0 0 32 32"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
    class="logo-taegeuk"
  >
    <!-- Red (upper) half of taegeuk -->
    <path
      d="M16 0 A16 16 0 0 1 16 32 A8 8 0 0 1 16 16 A8 8 0 0 0 16 0Z"
      fill="#C60C30"
    />
    <!-- Blue (lower) half of taegeuk -->
    <path
      d="M16 0 A16 16 0 0 0 16 32 A8 8 0 0 0 16 16 A8 8 0 0 1 16 0Z"
      fill="#003478"
    />
  </svg>
  <span class="logo-text">Living in Korea</span>
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }
  .logo:hover {
    text-decoration: none;
  }
  .logo-taegeuk {
    flex-shrink: 0;
  }
  .logo-text {
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-primary);
  }
</style>
