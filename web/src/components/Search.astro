---
// Inline search component — search bar in nav with dropdown results
---

<div class="search-wrapper" id="search-wrapper">
  <div class="search-input-wrapper">
    <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <input
      type="text"
      class="search-input"
      id="search-input"
      placeholder="Search..."
      autocomplete="off"
    />
  </div>
  <div class="search-results" id="search-results"></div>
</div>

<script is:inline>
  var pagefind = null;

  async function initPagefind() {
    if (pagefind) return pagefind;
    try {
      pagefind = await import('/pagefind/pagefind.js');
      await pagefind.init();
    } catch (e) {
      console.warn('Pagefind not available. Run a full build to enable search.');
      return null;
    }
    return pagefind;
  }

  var input = document.getElementById('search-input');
  var resultsEl = document.getElementById('search-results');
  var debounceTimer;

  input?.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    const query = input.value.trim();
    if (!query) {
      resultsEl.innerHTML = '';
      resultsEl.classList.remove('is-open');
      return;
    }
    debounceTimer = setTimeout(() => doSearch(query), 150);
  });

  input?.addEventListener('focus', () => {
    if (input.value.trim() && resultsEl.innerHTML) {
      resultsEl.classList.add('is-open');
    }
  });

  // Close on click outside
  document.addEventListener('click', (e) => {
    const wrapper = document.getElementById('search-wrapper');
    if (wrapper && !wrapper.contains(e.target)) {
      resultsEl.classList.remove('is-open');
    }
  });

  // Close on ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      resultsEl.classList.remove('is-open');
      input?.blur();
    }
    // Cmd/Ctrl+K to focus search
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      input?.focus();
    }
  });

  async function doSearch(query: string) {
    const pf = await initPagefind();
    if (!pf) {
      resultsEl.innerHTML = '<div class="search-no-results">Search available after build</div>';
      resultsEl.classList.add('is-open');
      return;
    }

    const search = await pf.search(query);
    const results = await Promise.all(
      search.results.slice(0, 6).map((r) => r.data())
    );

    if (results.length === 0) {
      resultsEl.innerHTML = `<div class="search-no-results">No results for "${query}"</div>`;
    } else {
      resultsEl.innerHTML = results.map((r) => `
        <a class="search-result-item" href="${r.url}">
          <span class="search-result-title">${r.meta?.title || r.url}</span>
          <span class="search-result-excerpt">${r.excerpt}</span>
        </a>
      `).join('');
    }
    resultsEl.classList.add('is-open');
  }
</script>

<style>
  .search-wrapper {
    position: relative;
  }
  .search-input-wrapper {
    display: flex;
    align-items: center;
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    padding: 0.3rem 0.6rem;
    gap: 0.4rem;
    transition: border-color 0.2s, background 0.2s;
  }
  .search-input-wrapper:focus-within {
    background: white;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(26, 86, 219, 0.1);
  }
  .search-icon {
    color: #9ca3af;
    flex-shrink: 0;
  }
  .search-input {
    border: none;
    background: none;
    outline: none;
    font-size: 0.85rem;
    color: var(--color-text);
    width: 140px;
    transition: width 0.2s;
  }
  .search-input::placeholder {
    color: #9ca3af;
  }
  .search-input:focus {
    width: 220px;
  }

  /* Dropdown results */
  .search-results {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    width: 380px;
    max-height: 420px;
    overflow-y: auto;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    z-index: 100;
  }
  .search-results.is-open {
    display: block;
  }

  .search-no-results {
    padding: 1rem;
    color: #6b7280;
    font-size: 0.85rem;
    text-align: center;
  }

  @media (max-width: 640px) {
    .search-input {
      width: 100px;
    }
    .search-input:focus {
      width: 150px;
    }
    .search-results {
      width: calc(100vw - 2rem);
      right: -1rem;
    }
  }
</style>

<style is:global>
  .search-result-item {
    display: block;
    padding: 0.75rem 1rem;
    text-decoration: none;
    border-bottom: 1px solid #f3f4f6;
    transition: background 0.15s;
  }
  .search-result-item:last-child {
    border-bottom: none;
  }
  .search-result-item:hover {
    background: #f9fafb;
  }
  .search-result-title {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }
  .search-result-excerpt {
    display: block;
    font-size: 0.8rem;
    color: #6b7280;
    line-height: 1.4;
  }
  .search-result-excerpt mark {
    background: #fef3c7;
    color: inherit;
    border-radius: 2px;
    padding: 0 1px;
  }
</style>
